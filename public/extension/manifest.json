{
  "manifest_version": 3,
  "name": "ClipIQ — Clipboard Intelligence",
  "version": "2.0.0",
  "description": "Floating clipboard manager. Save clips and paste them anywhere with one click.",
  "permissions": [
    "clipboardRead",
    "clipboardWrite", 
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open ClipIQ",
    "default_icon": { "128": "icon.png" }
  },
  "side_panel": { "default_path": "sidepanel.html" },
  "background": { "service_worker": "background.js" },
  "icons": { "128": "icon.png" }
}
