{
  "manifest_version": 3,
  "name": "ClipIQ — Clipboard Intelligence",
  "version": "1.0.0",
  "description": "Smart clipboard history. Auto-splits batches of emails and phone numbers into single-click items.",
  "permissions": ["clipboardRead", "clipboardWrite", "sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open ClipIQ"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "128": "icon.png"
  }
}
