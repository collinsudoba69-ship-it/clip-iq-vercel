{
  "manifest_version": 3,
  "name": "ClipIQ — Clipboard Intelligence",
  "version": "1.2.0",
  "description": "Floating clipboard manager for Gmail & any website. See all your clips and paste with one click.",
  "permissions": ["clipboardRead", "clipboardWrite", "sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Open ClipIQ",
    "default_icon": { "128": "icon.png" }
  },
  "side_panel": { "default_path": "sidepanel.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": { "128": "icon.png" }
}
